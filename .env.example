# Copy this file to .env and fill in your own values.
# .env is gitignored; .env.example is the public template.

# Google Fonts Developer API key — required by ./bin/refresh_fonts
# Generate one at: https://console.cloud.google.com (Web Fonts Developer API)
GOOGLE_FONTS_API_KEY=your_api_key_here

# Which font catalog drives the dropdown.
#   google  — Google Fonts catalog with the Google Docs-style modal (default)
#   system  — Server's installed fonts via fc-list (works offline)
FONT_SOURCE=google
